# Backend Environment Variables
# Copy this file to .env and fill in the values

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/smartheal

# GitHub OAuth App Configuration
# Create a GitHub OAuth App at: https://github.com/settings/developers
# Set the callback URL to: http://localhost:3001/api/github/callback
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here

# Session Secret (change this to a random string)
SESSION_SECRET=your_session_secret_here

# Server Configuration
PORT=3001

# SmartHeal SDK Configuration
# SMARTHEAL_PROJECT_ID is generated by SmartHeal when you register a project.
# Steps:
#   1. Start the SmartHeal backend
#   2. POST /api/projects  { "name": "my-app" }
#   3. Copy the returned `projectId` (e.g. proj_a1b2c3d4) here
# Never hardcode this value directly in code — always load from env.
SMARTHEAL_ENDPOINT=http://localhost:3001/jobs
SMARTHEAL_PROJECT_ID=proj_your_project_id_here
